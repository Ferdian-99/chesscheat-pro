{
  "manifest_version": 3,
  "name": "ChessCheat Pro",
  "version": "2.8",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "chesscheatextension@gmail.com"
    }
  },
  "description": "Premium chess analysis tool for chess.com - displays optimal moves with Stockfish engine, featuring a beautiful tournament-grade interface",
  "content_scripts": [
    {
      "js": ["scripts/main.js"],
      "matches": [
        "https://www.chess.com/*",
        "https://chess.com/*"
      ]
    }
  ]
}
